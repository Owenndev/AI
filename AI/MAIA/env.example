# ============================================================
# MAIA Agent OS — Environment Configuration
# Copiar este archivo como .env y ajustar los valores
# ============================================================

# ── LLM (llama-server corriendo localmente) ──────────────────
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_MODEL=qwen3.6-35b-a3b          # nombre que devuelve /v1/models
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_CONTEXT_SIZE=131072

# ── ComfyUI ──────────────────────────────────────────────────
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_OUTPUT_DIR=C:/AI/ComfyUI/output

# ── Base de datos ─────────────────────────────────────────────
DATABASE_PATH=C:/AI/MAIA/data/memory/maia.db

# ── Paths del proyecto ────────────────────────────────────────
MAIA_ROOT=C:/AI/MAIA
DATA_DIR=C:/AI/MAIA/data
OUTPUTS_DIR=C:/AI/MAIA/data/outputs
LOGS_DIR=C:/AI/MAIA/data/logs

# ── Servidor MAIA ────────────────────────────────────────────
MAIA_HOST=127.0.0.1
MAIA_PORT=8080
DEBUG=true

# ── Búsqueda web (SearXNG local) ─────────────────────────────
SEARXNG_URL=http://127.0.0.1:8080   # cuando lo instales
